# Backend Environment Configuration for BondCredit Phase 1
# Copy this file to .env and fill in the values

# ========== Blockchain Configuration ==========

# XDC Testnet RPC URL
# This is the JSON-RPC endpoint for connecting to the XDC blockchain (Apothem testnet)
# The backend uses this to query events, send transactions, and check balances
XDC_TESTNET_RPC=https://51.rpc.thirdweb.com

# Private Key for Deployer/Scripts (with or without 0x prefix)
# This private key signs transactions for the approval and deposit scripts
# Format: 64 hex characters (0x optional)
# WARNING: Never commit this to version control. Store it in .env (gitignored)
# This is typically for testing only. Production should use a hardware wallet or key management service.
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Vault Contract Address
# The deployed BondCreditVault contract address on XDC testnet
# Example: 0xCEa6DF320e3233e17e3f66949F51D0ef10ad4a08
# You get this after running: npx hardhat run scripts/deploy.js --network xdcTestnet
VAULT_ADDRESS=0xCEa6DF320e3233e17e3f66949F51D0ef10ad4a08

# USDC Token Address
# The USDC token contract address on XDC testnet
# This is the token users deposit into the vault
# Example: 0xb5AB69F7bBada22B28e79C8FFAECe55eF1c771D4
USDC_ADDRESS=0xb5AB69F7bBada22B28e79C8FFAECe55eF1c771D4

# ========== Database Configuration ==========

# PostgreSQL Connection URL
# Format: postgresql://user:password@host:port/database
# For local development with Docker:
#   postgresql://postgres:postgres@localhost:5432/bondcredit
# For production: Use a managed database service (AWS RDS, Supabase, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bondcredit

# ========== Backend Server Configuration ==========

# Backend API Port
# The port the NestJS server listens on
# Default: 3001
BACKEND_PORT=3001

# Node Environment
# Options: development, production, test
NODE_ENV=development

# ========== Event Listener Configuration ==========

# Block Look-back
# How many blocks to look back when the listener starts for the first time
# Default: 1000 blocks (~3.3 hours on XDC)
LISTENER_LOOKBACK_BLOCKS=1000

# Polling Interval (milliseconds)
# How often the listener checks for new events
# Default: 12000 (12 seconds, matching XDC's average block time)
LISTENER_POLL_INTERVAL=12000

# Block Batch Size
# How many blocks to query in one RPC call
# Default: 100 (limits RPC payload size)
LISTENER_BLOCK_BATCH_SIZE=100

# ========== Logging Configuration ==========

# Log Level
# Options: error, warn, log, debug, verbose
LOG_LEVEL=log

# ========== Feature Flags (for Phase 1) ==========

# Enable real-time event listening (WebSocket)
# If true: use WebSocket for real-time events (if RPC supports it)
# If false: use polling (default, more stable)
ENABLE_REALTIME_LISTENER=false

# Enable event replay
# If true: Allows re-processing old blocks
ENABLE_EVENT_REPLAY=true
