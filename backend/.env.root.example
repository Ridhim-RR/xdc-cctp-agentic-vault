# Example .env for deploying to XDC testnet
# Replace with your private key (0x...)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# XDC Testnet RPC URL (Apothem)
XDC_TESTNET_RPC=https://apothem.rpc.thirdweb.com

# USDC token address on XDC testnet (replace with actual test USDC)
USDC_ADDRESS=0x0000000000000000000000000000000000000000
